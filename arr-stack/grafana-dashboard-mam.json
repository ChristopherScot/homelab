      "targets": [{"expr": "mam_ratio", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "short", "decimals": 2, "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "yellow", "value": 0.95}, {"color": "green", "value": 1.0}]}}}
    },
    {
      "type": "stat",
      "title": "Hit-and-Runs",
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 0},
